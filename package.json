{
  "name": "unicode-spinners",
  "version": "3.2.0",
  "description": "Unicode spinner animations as raw frame data",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./braille": {
      "import": {
        "types": "./dist/braille.d.ts",
        "default": "./dist/braille.js"
      },
      "require": {
        "types": "./dist/braille.d.cts",
        "default": "./dist/braille.cjs"
      }
    }
  },
  "bin": {
    "unicode-spinners": "./scripts/demo.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts"
  ],
  "sideEffects": false,
  "scripts": {
    "lint": "eslint src",
    "format": "prettier --write src",
    "build": "tsup",
    "release": "changeset publish",
    "test": "vitest run",
    "unicode-spinners-v2": "node scripts/demo.cjs --all",
    "manage": "node scripts/manager.cjs",
    "demo": "node scripts/demo.cjs",
    "demo:list": "node scripts/demo.cjs --list",
    "demo:review": "node scripts/demo.cjs --review",
    "demo:web": "node scripts/demo.cjs --web",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chatbotstudios/unicode-spinners.git"
  },
  "homepage": "https://github.com/chatbotstudios/unicode-spinners",
  "keywords": [
    "braille",
    "spinner",
    "unicode",
    "animation",
    "loading",
    "cli",
    "terminal"
  ],
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nps": "^5.10.0",
    "prettier": "^3.9.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
